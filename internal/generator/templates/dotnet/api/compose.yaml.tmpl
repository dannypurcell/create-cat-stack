services:
  {{.ProjectName}}-api:
    build:
      context: ./api
      dockerfile: Dockerfile
    ports:
      - "8080:8080"
    environment:
      - ENVIRONMENT=development
      - DB_HOST={{.ProjectName}}-db
      - DB_PORT=5432
      - DB_NAME={{.ProjectName}}
    secrets:
      - db_user
      - db_password
    depends_on:
      {{.ProjectName}}-db:
        condition: service_healthy
    restart: unless-stopped

  {{.ProjectName}}-db:
    image: postgres:16-alpine
    environment:
      POSTGRES_DB: {{.ProjectName}}
      POSTGRES_USER_FILE: /run/secrets/db_user
      POSTGRES_PASSWORD_FILE: /run/secrets/db_password
    ports:
      - "5432:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data
    secrets:
      - db_user
      - db_password
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U $$(cat /run/secrets/db_user) -d {{.ProjectName}}"]
      interval: 5s
      timeout: 3s
      retries: 5

volumes:
  pgdata:

secrets:
  db_user:
    file: ./secrets/db_user.txt
  db_password:
    file: ./secrets/db_password.txt
