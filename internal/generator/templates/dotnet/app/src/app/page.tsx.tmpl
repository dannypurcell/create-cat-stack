'use client';

import { useState } from 'react';
import { useGreetingService } from '@/providers';
import GreetingCard from '@/components/GreetingCard';
import LoginForm from '@/components/LoginForm';
import type { Greeting } from '@/models/Greeting';

export default function Home() {
  const greetingService = useGreetingService();

  const [loggedIn, setLoggedIn] = useState(false);
  const [email, setEmail] = useState('');
  const [password, setPassword] = useState('');
  const [greeting, setGreeting] = useState<Greeting | null>(null);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState<string | null>(null);

  async function handleLogin() {
    if (!email || !password) return;
    setLoading(true);
    setError(null);
    try {
      const data = await greetingService.fetchRandom();
      setGreeting(data);
      setLoggedIn(true);
    } catch {
      setError('Could not reach the API. Is the stack running?');
    } finally {
      setLoading(false);
    }
  }

  async function handleNewGreeting() {
    setLoading(true);
    setError(null);
    try {
      const data = await greetingService.fetchRandom();
      setGreeting(data);
    } catch {
      setError('Failed to fetch greeting');
    } finally {
      setLoading(false);
    }
  }

  function handleSignOut() {
    setLoggedIn(false);
    setGreeting(null);
    setPassword('');
  }

  if (loggedIn && greeting) {
    return (
      <GreetingCard
        email={email}
        greeting={greeting}
        loading={loading}
        onNewGreeting={handleNewGreeting}
        onSignOut={handleSignOut}
      />
    );
  }

  return (
    <LoginForm
      email={email}
      password={password}
      loading={loading}
      error={error}
      projectName="{{.ProjectName}}"
      onEmailChange={setEmail}
      onPasswordChange={setPassword}
      onLogin={handleLogin}
    />
  );
}
