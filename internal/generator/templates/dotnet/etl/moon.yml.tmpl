language: 'unknown'
tasks:
  build:
    command: 'dotnet build'
  test:
    command: 'dotnet test'
  run:
    command: 'dotnet run'
  docker-build:
    command: 'docker compose build {{.ProjectName}}-etl'
  docker-up:
    command: 'docker compose up {{.ProjectName}}-etl -d'
  logs:
    command: 'docker compose logs {{.ProjectName}}-etl -f'
