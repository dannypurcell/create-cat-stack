name: {{.ProjectName}}

# Secret files — set SECRETS_DIR to override location.
# Local dev: create ./secrets/<name> files (gitignored).
# Prod:      deploy script writes these and sets SECRETS_DIR.
secrets:
  {{.ProjectName}}_db_password:
    file: ${SECRETS_DIR:-./secrets}/db_password
{{- if eq .Auth "pocket-id"}}
  {{.ProjectName}}_pocket_id_key:
    file: ${SECRETS_DIR:-./secrets}/pocket_id_key
{{- end}}

services:

  # --- Auth / Reverse Proxy ---
  {{.ProjectName}}-auth:
    image: {{.ProjectName}}-auth:latest
    build:
      context: .
      dockerfile: auth/Dockerfile
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - caddy-data:/data
{{- if eq .Auth "pocket-id"}}
      - pocket-id-data:/srv/data
{{- end}}
    environment:
      DOMAIN: ${DOMAIN:-localhost}
    networks:
      - {{.ProjectName}}-network
    depends_on:
      {{.ProjectName}}-api:
        condition: service_started
    restart: unless-stopped

  # --- API Backend ---
  {{.ProjectName}}-api:
    image: {{.ProjectName}}-api:latest
    build:
      context: .
      dockerfile: api/Dockerfile
    environment:
      PG_HOST: {{.ProjectName}}-db
      PG_USER: postgres
      PG_DB: postgres
      PG_PORT: "5432"
{{- if ne .Auth "none"}}
      OIDC_ISSUER_URL: ${OIDC_ISSUER_URL:-http://{{.ProjectName}}-auth}
      OIDC_CLIENT_ID: {{.ProjectName}}-app
{{- end}}
    networks:
      - {{.ProjectName}}-network
    depends_on:
      {{.ProjectName}}-db:
        condition: service_healthy
    restart: unless-stopped
{{- if ne .Frontend "none"}}

  # --- Frontend App ---
  {{.ProjectName}}-app:
    image: {{.ProjectName}}-app:latest
    build:
      context: .
      dockerfile: app/Dockerfile
    networks:
      - {{.ProjectName}}-network
    restart: unless-stopped
{{- end}}

  # --- Database ---
  {{.ProjectName}}-db:
    image: {{.ProjectName}}-db:latest
    build:
      context: ./db
      dockerfile: Dockerfile
    environment:
      POSTGRES_USER: postgres
      POSTGRES_DB: postgres
      POSTGRES_HOST_AUTH_METHOD: trust
    volumes:
      - {{.ProjectName}}-db:/var/lib/postgresql
    networks:
      - {{.ProjectName}}-network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres -h localhost -p 5432 && ! [ -f /tmp/pgschema-failed ]"]
      start_period: 3s
      start_interval: 0.5s
      interval: 3s
      timeout: 1s
      retries: 5
    restart: unless-stopped
{{- if .DataProcessing}}

  # --- Data Processing (ETL) ---
  {{.ProjectName}}-etl:
    image: {{.ProjectName}}-etl:latest
    build:
      context: .
      dockerfile: etl/Dockerfile
    environment:
      PG_HOST: {{.ProjectName}}-db
      PG_USER: postgres
      PG_DB: postgres
      PG_PORT: "5432"
    networks:
      - {{.ProjectName}}-network
    depends_on:
      {{.ProjectName}}-db:
        condition: service_healthy
    restart: "no"   # ETL is a job runner — triggered via API/cron, not a daemon
{{- end}}

volumes:
  {{.ProjectName}}-db:
  caddy-data:
{{- if eq .Auth "pocket-id"}}
  pocket-id-data:
{{- end}}

networks:
  {{.ProjectName}}-network:
