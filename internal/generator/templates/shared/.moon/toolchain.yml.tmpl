# Moon toolchain configuration
# https://moonrepo.dev/docs/config/toolchain
{{- if eq .Backend "dotnet"}}

# .NET projects use dotnet CLI directly — no Moon-managed runtime.
# Moon orchestrates tasks; dotnet SDK must be installed on the host.
{{- end}}
{{- if eq .Backend "python-fastapi"}}

python:
  version: '3.12'
{{- end}}
{{- if eq .Backend "go-echo"}}

go:
  version: '1.22'
{{- end}}
{{- if ne .Frontend "none"}}

node:
  version: '22'
  packageManager: 'npm'
{{- end}}
