services:
  {{.ProjectName}}-auth:
    image: {{.ProjectName}}-auth:latest
    build:
      context: ..
      dockerfile: auth/Dockerfile
    ports:
      - "80:80"
      - "443:443"
{{- if eq .Auth "pocket-id"}}
      - "1411:1411"   # Pocket-ID admin UI
{{- end}}
    volumes:
      - caddy-data:/data
{{- if eq .Auth "pocket-id"}}
      - pocket-id-data:/srv/data
{{- end}}
    environment:
      DOMAIN: ${DOMAIN:-localhost}
{{- if eq .Auth "jumpcloud"}}
      OIDC_CLIENT_ID: ${OIDC_CLIENT_ID:-change-me}
      OIDC_ISSUER_URL: ${OIDC_ISSUER_URL:-https://oauth.id.jumpcloud.com/}
    secrets:
      - {{.ProjectName}}_oidc_client_secret
      - {{.ProjectName}}_jwt_shared_key
{{- end}}
    networks:
      - {{.ProjectName}}-network
    restart: unless-stopped

volumes:
  caddy-data:
{{- if eq .Auth "pocket-id"}}
  pocket-id-data:
{{- end}}

networks:
  {{.ProjectName}}-network:
