{{- if eq .Auth "pocket-id" -}}
# Caddyfile for {{.ProjectName}}
# Pocket-ID runs on localhost:1411 inside this container.
# API and app are separate containers on the Docker network.

{$SITE_ADDRESS:http://localhost} {
	encode gzip

	# Auth endpoints — proxy to local pocket-id
	handle /api/oidc/* {
		reverse_proxy localhost:1411
	}

	# API routes
	handle /api/* {
		uri strip_prefix /api
		reverse_proxy {{.ProjectName}}-api:8080
	}

	# Everything else — app frontend{{- if ne .Frontend "none" }}
	handle {
		reverse_proxy {{.ProjectName}}-app:3000
	}
	{{- else }}
	handle {
		respond "{{.ProjectName}} API is running. No frontend configured." 200
	}
	{{- end}}
}
{{- else if eq .Auth "jumpcloud" -}}
# Caddyfile for {{.ProjectName}}
# Auth provider: JumpCloud (OIDC via caddy-security)

{
	security {
		oauth identity provider jumpcloud {
			realm jumpcloud
			driver generic
			client_id {$OIDC_CLIENT_ID}
			client_secret {$OIDC_CLIENT_SECRET}
			scopes openid email profile
			metadata_url https://oauth.id.jumpcloud.com/.well-known/openid-configuration
		}

		authentication portal myportal {
			crypto default token lifetime 3600
			crypto key sign-verify {$JWT_SHARED_KEY}
			enable identity provider jumpcloud
			cookie insecure {$COOKIE_INSECURE:off}
		}

		authorization policy mypolicy {
			set auth url /auth/
			allow roles authp/user authp/admin
			crypto key verify {$JWT_SHARED_KEY}
		}
	}
}

{$SITE_ADDRESS:http://localhost} {
	encode gzip

	route /auth* {
		authenticate with myportal
	}

	route /api/* {
		authorize with mypolicy
		uri strip_prefix /api
		reverse_proxy {{.ProjectName}}-api:8080
	}

	route {
		authorize with mypolicy
		{{- if ne .Frontend "none" }}
		reverse_proxy {{.ProjectName}}-app:3000
		{{- else }}
		respond "{{.ProjectName}} API is running. No frontend configured." 200
		{{- end}}
	}
}
{{- else -}}
# Caddyfile for {{.ProjectName}}
# Auth provider: {{.Auth}} (external)
# API and app are separate containers on the Docker network.

{$SITE_ADDRESS:http://localhost} {
	encode gzip

	# API routes
	handle /api/* {
		uri strip_prefix /api
		reverse_proxy {{.ProjectName}}-api:8080
	}

	# Everything else — app frontend{{- if ne .Frontend "none" }}
	handle {
		reverse_proxy {{.ProjectName}}-app:3000
	}
	{{- else }}
	handle {
		respond "{{.ProjectName}} API is running. No frontend configured." 200
	}
	{{- end}}
}
{{- end}}
