services:
  {{.ProjectName}}-db:
    image: {{.ProjectName}}-db:latest
    build:
      context: .
      dockerfile: Dockerfile
    environment:
      POSTGRES_USER: postgres
      POSTGRES_DB: postgres
      POSTGRES_HOST_AUTH_METHOD: trust
    volumes:
      - {{.ProjectName}}-db:/var/lib/postgresql
    ports:
      - "5432:5432"
    networks:
      - {{.ProjectName}}-network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres -h localhost -p 5432 && ! [ -f /tmp/pgschema-failed ]"]
      start_period: 3s
      start_interval: 0.5s
      interval: 3s
      timeout: 1s
      retries: 5

volumes:
  {{.ProjectName}}-db:

networks:
  {{.ProjectName}}-network:
