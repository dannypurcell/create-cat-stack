# {{.ProjectName}} environment configuration
# Copy this file to .env and fill in the values.
# .env is gitignored — never commit secrets.

# Domain for the application (localhost for local dev)
DOMAIN=localhost

# Database
PG_HOST={{.ProjectName}}-db
PG_USER=postgres
PG_DB=postgres
PG_PORT=5432
{{- if eq .Auth "pocket-id"}}

# Auth (Pocket-ID)
OIDC_ISSUER_URL=http://{{.ProjectName}}-auth
OIDC_CLIENT_ID={{.ProjectName}}-app
{{- else if eq .Auth "cognito"}}

# Auth (Cognito)
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_REGION=us-east-1
{{- else if eq .Auth "auth0"}}

# Auth (Auth0)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_AUDIENCE=
{{- else if eq .Auth "clerk"}}

# Auth (Clerk)
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
{{- else if eq .Auth "keycloak"}}

# Auth (Keycloak)
KEYCLOAK_URL=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
{{- else if eq .Auth "jumpcloud"}}

# Auth (JumpCloud OIDC via caddy-security)
# Create an SSO application in JumpCloud admin: https://console.jumpcloud.com/sso
# Application type: OAuth2 / OIDC
# Redirect URI: https://<your-domain>/auth/oauth2/jumpcloud/authorization-code-callback
# Issuer URL is fixed: https://oauth.id.jumpcloud.com/
OIDC_ISSUER_URL=https://oauth.id.jumpcloud.com/
OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET goes in secrets/oidc_client_secret (not .env)
# JWT_SHARED_KEY goes in secrets/jwt_shared_key — auto-generated by: just secrets
{{- end}}

# Secrets directory (override for production)
# SECRETS_DIR=/opt/{{.ProjectName}}/secrets
